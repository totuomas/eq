{
  "manifest_version": 3,
  "name": "Simple YouTube EQ",
  "version": "1.0",
  "description": "3-band equalizer for YouTube",
  "permissions": ["activeTab", "scripting", "storage"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}