{
  "manifest_version": 3,
  "name": "Simple YouTube EQ",
  "version": "1.0",
  "description": "3-band equalizer for YouTube",
  "permissions": ["activeTab", "scripting", "storage"],

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },

  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}